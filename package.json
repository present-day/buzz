{
  "name": "@present-day/buzz",
  "version": "0.1.0",
  "description": "Cross-platform haptic and audio feedback library for web applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "build:playground": "esbuild playground/main.ts --bundle --outfile=docs/playground.js --minify --platform=browser",
    "build:all": "npm run build && npm run build:playground",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "haptics",
    "feedback",
    "audio",
    "webaudio",
    "vibration",
    "ui",
    "interaction"
  ],
  "author": "Present Day",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/present-day/buzz.git"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=18"
  }
}